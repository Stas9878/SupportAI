# === База данных ===
DATABASE_URL=postgresql+asyncpg://support:support_pass@localhost:5432/support_db

# Отдельные компоненты (опционально, для удобства)
DB_USER=support
DB_PASSWORD=support_pass
DB_NAME=support_db
DB_HOST=localhost
DB_PORT=5432

# === Ollama / LLM ===
OLLAMA_BASE_URL=http://localhost:11434

# Модель для генерации ответов
LLM_MODEL=llama3.1:latest

# Температура генерации
LLM_TEMPERATURE=0.1

# Максимальное число токенов в ответе модели
LLM_MAX_TOKENS=2048

# === LangSmith (мониторинг и трейсинг) ===
LANGSMITH_TRACING=true

# API ключ для аутентификации в LangSmith
LANGSMITH_API_KEY=

# Имя проекта в дашборде LangSmith
LANGSMITH_PROJECT=support-ai

# Рабочее пространство в LangSmith
LANGSMITH_WORKSPACE_ID=

# Эндпоинт для обращения к LangSmith
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# === Приложение ===
# Хост и порт для Uvicorn (веб-сервер)
APP_HOST=0.0.0.0
APP_PORT=8000

# Режим запуска: dev (с авто-релоадом) или prod
APP_ENV=dev

# Секретный ключ для подписи токенов и сессий
# Сгенерируйте безопасное значение:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-prod

# === Telegram (алерты для критичных заявок) ===
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID пользователя/канала для получения уведомлений
# Получите через @userinfobot
TELEGRAM_CHAT_ID=

# Порог приоритета для отправки алертов (critical/high/medium/low)
ALERT_PRIORITY_THRESHOLD=critical

# === Безопасность ===
# Разрешённые источники для CORS (укажите фронтенд, если есть)
# Формат: через запятую, без пробелов
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Лимит запросов в минуту на одного пользователя (rate limiting)
RATE_LIMIT_PER_MINUTE=60
